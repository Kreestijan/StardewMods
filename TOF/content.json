        "Kree.TOF_Objects": [
          {
            "Asset": "Mods/Kree.TOF/Objects"
          }
        ]
      }
    },
    {
      "Action": "Include",
      "FromFile": "data/mirror_koi.json",
      "When": {
        "EnableMirrorKoi": "true"
      }
    },
    {
      "Action": "Include",
      "FromFile": "data/reed_catfish.json",
      "When": {
        "EnableReedCatfish": "true"
      }
    },
    {
      "Action": "Include",
      "FromFile": "data/mossfin.json",
      "When": {
        "EnableMossfin": "true"
      }
    },
    {
      "Action": "Include",
      "FromFile": "data/lantern_eel.json",
      "When": {
        "EnableLanternEel": "true"
      }
    },
    {
      "Action": "Include",
      "FromFile": "data/stormray.json",
      "When": {
        "EnableStormray": "true"
      }
    },
    {
      "Action": "Include",
      "FromFile": "data/surf_perch.json",
      "When": {
        "EnableSurfPerch": "true"
      }
    },
    {
      "Action": "Include",
      "FromFile": "data/hanami_koi.json",
      "When": {
        "EnableHanamiKoi": "true"
      }
    },
    {
      "Action": "Include",
      "FromFile": "data/coralphin.json",
      "When": {
        "EnableCoralphin": "true"
      }
    },
    {
      "Action": "Include",
      "FromFile": "data/orcanini.json",
      "When": {
        "EnableOrcanini": "true"
      }
    },
    {
      "Action": "EditData",
      "Target": "Data/FishPondData",
      "MoveEntries": [
        {
          "ID": "tof_mirror_koi",
          "ToPosition": "Top"
        },
        {
          "ID": "tof_reed_catfish",
          "AfterID": "tof_mirror_koi"
