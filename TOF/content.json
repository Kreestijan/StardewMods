{
  "Format": "2.9.0",
  "ConfigSchema": {
    "EnableMirrorKoi": {
      "AllowValues": "true, false",
      "Default": "true"
    },
    "EnableReedCatfish": {
      "AllowValues": "true, false",
      "Default": "true"
    },
    "EnableMossfin": {
      "AllowValues": "true, false",
      "Default": "true"
    },
    "EnableLanternEel": {
      "AllowValues": "true, false",
      "Default": "true"
    },
    "EnableStormray": {
      "AllowValues": "true, false",
      "Default": "true"
    },
    "EnableSurfPerch": {
      "AllowValues": "true, false",
      "Default": "true"
    },
    "EnableHanamiKoi": {
