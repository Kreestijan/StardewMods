        {
          "ID": "tof_mossfin",
          "AfterID": "tof_reed_catfish"
        },
        {
          "ID": "tof_lantern_eel",
          "AfterID": "tof_mossfin"
        },
        {
          "ID": "tof_stormray",
          "AfterID": "tof_lantern_eel"
        },
        {
          "ID": "tof_surf_perch",
          "AfterID": "tof_stormray"
        },
        {
          "ID": "tof_hanami_koi",
          "AfterID": "tof_surf_perch"
        },
        {
          "ID": "tof_coralphin",
          "AfterID": "tof_hanami_koi"
        },
        {
          "ID": "tof_orcanini",
